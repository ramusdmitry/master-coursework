# База данных
# Для SQLite (по умолчанию):
DATABASE_URL=sqlite:///./ml_service.db

# Для PostgreSQL (пример):
# DATABASE_URL=postgresql://user:password@localhost:5432/ml_service

# Секретный ключ для JWT токенов
# ВАЖНО: Измените на случайную строку в продакшене!
# Можно сгенерировать через: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=your-secret-key-change-in-production

# Токен подтверждения для удаления истории
# ВАЖНО: Измените на случайную строку в продакшене!
DELETE_CONFIRM_TOKEN=DELETE_CONFIRM_TOKEN


